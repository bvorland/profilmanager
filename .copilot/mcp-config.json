{
  "mcpServers": {
    "EXAMPLE-github": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/github-mcp-server"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "profilmanager": {
      "command": "pm",
      "args": ["mcp", "serve"]
    }
  }
}
