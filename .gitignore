# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/pm
/pm.exe

# Go workspace / module noise
go.work
go.work.sum
vendor/

# Coverage / profiling
*.prof
coverage.txt
coverage.out
coverage.html

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# GoReleaser output (configured via dist: in .goreleaser.yaml)
/build/

# Probe artifacts (regenerated by scripts/isolation/run-matrix.*; may
# contain real tenant IDs / paths from the host machine they ran on)
/artifacts/

# Squad agentic development history (kept private)
/.squad/

# Squad framework artifacts (Squad-only — useless without /.squad/)
.github/agents/squad.agent.md
.github/workflows/squad-heartbeat.yml
.github/workflows/squad-issue-assign.yml
.github/workflows/squad-triage.yml
.github/workflows/sync-squad-labels.yml
.copilot/skills/agent-collaboration/
.copilot/skills/error-recovery/
.copilot/skills/git-workflow/
.copilot/skills/reviewer-protocol/
.copilot/skills/secret-handling/
.copilot/skills/session-recovery/
.copilot/skills/squad-conventions/
.copilot/skills/test-discipline/
