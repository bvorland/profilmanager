  "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
  "version": "0.1.0",
  "description": "Multi-environment developer profile manager (pm) — Azure, GitHub, kubectl, git identity, secrets, from one profile.",
  "homepage": "https://github.com/bvorland/profilmanager",
  "license": "MIT",
  "notes": [
    "Add 'pm' to your shell so PM_SESSION_ID is bound for every shell:",
